#!/usr/bin/env bash
# afm CLI — thin Docker wrapper.
# This is the only supported way to run the afm binary during development.
# Never invoke `cargo run -p afm-cli` on the host.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

exec docker compose run --rm --no-TTY dev \
    cargo run --quiet --package afm-cli -- "$@"
