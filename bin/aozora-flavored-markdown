#!/usr/bin/env bash
# aozora-flavored-markdown CLI — thin Docker wrapper.
# This is the only supported way to run the aozora-flavored-markdown binary during development.
# Never invoke `cargo run -p aozora-flavored-markdown-cli` on the host.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

exec docker compose run --rm --no-TTY dev \
    cargo run --quiet --package aozora-flavored-markdown-cli -- "$@"
