#!/usr/bin/env bash
# xtask — project automation (upstream-diff, upstream-sync, new-adr,
# spec-refresh). Always runs inside the dev container.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$REPO_ROOT"

exec docker compose run --rm dev \
    cargo run --quiet --package xtask -- "$@"
