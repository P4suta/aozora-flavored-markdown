# Rust
/target
/crates/*/target
**/*.rs.bk

# Cargo
Cargo.lock.bak
# CARGO_HOME inside the dev container resolves to /workspace/.cargo, which bind-mounts
# onto this directory. The registry/git caches underneath are docker volumes and
# should never be tracked.
/.cargo/
# Inner Cargo.lock generated when building upstream/comrak standalone (e.g. for
# running its own test suite). The workspace-root Cargo.lock is authoritative.
/upstream/comrak/Cargo.lock

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# mdbook build output
/crates/aozora-flavored-markdown-book/book/

# wasm-pack output (generated; consumed by playground/ via file: link)
/crates/aozora-flavored-markdown-wasm/pkg/

# Playground build artefacts
/playground/dist/
/playground/.vite/

# Coverage
/coverage/
*.profraw
*.profdata
lcov.info

# Node (for aozora-flavored-markdown-book, playwright)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
playwright-report/
test-results/

# Fuzz (cargo-fuzz crates live at crates/<crate>/fuzz/, e.g.
# crates/aozora-flavored-markdown/fuzz/ — the bare `fuzz/*` form matched a
# nonexistent top-level dir and never ignored anything).
crates/*/fuzz/target/
crates/*/fuzz/corpus/
crates/*/fuzz/artifacts/

# Criterion
/target/criterion/

# dhat heap-profile output (written to the workspace root by `just dhat`)
dhat-heap.json

# Local env overrides
.env
.env.local
/docker-compose.override.yml

# Ad-hoc scratch files (render outputs, debug dumps, …)
.tmp-*

# macOS junk in WSL mounts
:2e*

# Personal Claude Code settings (do not check in)
.claude/settings.local.json
.claude/scheduled_tasks.lock
CLAUDE.md
CLAUDE.local.md
